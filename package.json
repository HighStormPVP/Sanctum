{
  "name": "sanctum",
  "productName": "Sanctum",
  "version": "0.4.5",
  "description": "Sanctum — a private, fully-local AI workspace. Chat, vision, code, video analysis, and agentic tasks, all running on your own machine.",
  "main": "main.js",
  "scripts": {
    "start": "node launch.js",
    "dev": "node launch.js --enable-logging",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "author": "Aiden",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "pdf-parse": "^1.1.1"
  },
  "build": {
    "appId": "com.aiden.sanctum",
    "productName": "Sanctum",
    "publish": null,
    "afterPack": "build/afterPack.js",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "launch.js",
      "index.html",
      "style.css",
      "models.json",
      "download-catalog.json",
      "lib/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json",
      "!**/{.DS_Store,Thumbs.db,*.log}",
      "!.remember/**/*",
      "!.git/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "zip",
          "arch": ["arm64", "x64"]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "dmg": {
      "title": "Sanctum ${version}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Sanctum"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "category": "Development"
    }
  }
}
